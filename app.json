{
  "expo": {
    "name": "Agendamentos Acadêmicos",
    "slug": "agendamentos-academicos",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1F3864"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "br.edu.fatec.agendamentos"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#1F3864"
      },
      "package": "br.edu.fatec.agendamentos"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-sqlite"
    ],
    "scheme": "agendamentos",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "770dfec9-506c-4517-b7e4-00fed65a659c"
      }
    },
    "owner": "llsalgado"
  }
}
