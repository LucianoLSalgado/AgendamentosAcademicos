# backend/.env
# NUNCA commite o .env no git

# Secrets JWT — use strings longas e aleatórias em produção
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=substitua-por-uma-chave-longa-e-aleatoria
REFRESH_SECRET=substitua-por-outra-chave-diferente-e-aleatoria

# Porta do servidor (padrão: 3000)
PORT=3000

# Ambiente
NODE_ENV=development